# ============================================================
# Copier ce fichier en .env avant de lancer le projet
# cp .env.example .env
# Ne jamais committer le fichier .env
# ============================================================

# MinIO (Data Lake)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# Buckets MinIO — 3 zones du Data Lake
BUCKET_RAW=raw-zone
BUCKET_CLEAN=clean-zone
BUCKET_CURATED=curated-zone

# MongoDB — base de données des métadonnées
MONGO_URI=mongodb://mongo:27017
MONGO_DB=hackathon2026

# Services internes
OCR_SERVICE_URL=http://ocr:5001
VALIDATION_SERVICE_URL=http://validation:5002
BACKEND_URL=http://backend:4000

# Airflow
AIRFLOW_UID=1000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# PostgreSQL (utilisé par Airflow)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Node.js backend
NODE_ENV=development
PORT_API=4000

# React frontend
REACT_APP_API_URL=http://localhost:4000
PORT_FRONT=3000